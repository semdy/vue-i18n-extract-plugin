{
  "name": "example-marko",
  "description": "Sample app that demonstrates the power of building UI components using Marko, Vite, and Remix",
  "version": "1.0.0",
  "dependencies": {
    "marko": "^6.0.0",
    "mitt": "^3.0.1"
  },
  "devDependencies": {
    "@marko/vite": "^5.4.4",
    "@types/express": "^5.0.6",
    "cross-env": "^10.1.0",
    "express": "^5.2.1",
    "extract-i18n-plugin": "^1.1.22",
    "prettier-plugin-marko": "^4.0.8",
    "rimraf": "^6.1.3",
    "vite": "^8.0.0"
  },
  "private": true,
  "scripts": {
    "build": "rimraf dist && cross-env NODE_ENV=production extract-i18n && vite build --app",
    "dev": "NODE_ENV=development extract-i18n && vite",
    "preview": "npm run build && npm start",
    "start": "cross-env NODE_ENV=production node --enable-source-maps index.ts",
    "extract-i18n": "extract-i18n"
  },
  "type": "module"
}
